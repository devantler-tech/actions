{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        { "type": "generic", "path": ".github/workflows/dependency-review.yaml" },
        { "type": "generic", "path": ".github/workflows/validate-go-project.yaml" },
        { "type": "generic", "path": ".github/workflows/update-agent-skills.yaml" },
        { "type": "generic", "path": ".github/workflows/run-dotnet-tests.yaml" },
        { "type": "generic", "path": ".github/workflows/scan-for-todo-comments.yaml" },
        { "type": "generic", "path": "run-dotnet-tests/action.yaml" }
      ],
      "changelog-sections": [
        { "type": "feat", "section": "Features" },
        { "type": "fix", "section": "Bug Fixes" },
        { "type": "perf", "section": "Performance Improvements" },
        { "type": "refactor", "section": "Code Refactoring" },
        { "type": "ci", "section": "Continuous Integration" },
        { "type": "build", "section": "Build System" },
        { "type": "docs", "section": "Documentation", "hidden": true },
        { "type": "test", "section": "Tests", "hidden": true },
        { "type": "chore", "section": "Miscellaneous", "hidden": true }
      ]
    }
  }
}
